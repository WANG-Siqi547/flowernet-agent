# FlowerNet 环境变量模板
# 复制为 .env 后填写；不要提交 .env 到 Git

# =========================
# Primary provider: DeepSeek V4
# =========================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash
GENERATOR_PROVIDER=deepseek
GENERATOR_PROVIDER_CHAIN=deepseek
GENERATOR_MODEL=deepseek-v4-flash
GENERATOR_DEEPSEEK_MODEL=deepseek-v4-flash
OUTLINER_PROVIDER=deepseek
OUTLINER_PROVIDER_CHAIN=deepseek
OUTLINER_MODEL=deepseek-v4-flash
OUTLINER_DEEPSEEK_MODEL=deepseek-v4-flash

# =========================
# Optional provider: Azure
# =========================
AZURE_OPENAI_API_KEY=
OUTLINER_AZURE_API_KEY=
GENERATOR_AZURE_API_KEY=
AZURE_OPENAI_API_BASE=https://poffices-ai.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# ====================================
# Secondary fallback: DashScope(GLM-5)
# ====================================
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=glm-5
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# =========================
# Optional providers
# =========================
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# =========================
# Local dev helper
# =========================
NO_PROXY=localhost,127.0.0.1
no_proxy=localhost,127.0.0.1
